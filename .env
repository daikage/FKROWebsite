# --- FORTKNOX NEWS CONFIGURATION ---

# Option A: Industry-wide news (Already set to Nigeria Outsourcing/BPO)
VITE_NEWS_RSS_URL=https://news.google.com/rss/search?q=outsourcing+OR+BPO+Nigeria+OR+"Fort+Knox+Outsourcing"&hl=en&gl=NG&ceid=NG:en

# Option B: Specific Fort Knox Blog Feed 
# (Note: Using rss2json.com is recommended to bypass CORS issues in React)
VITE_FK_NEWS_RSS=https://api.rss2json.com/v1/api.json?rss_url=https://www.fortknoxguards.com/feed/

# Polling interval: 10 minutes (600,000ms) to stay within API limits
VITE_FK_NEWS_POLL_MS=600000

# Metadata for your UI components
VITE_SITE_NAME="Fort Knox Group Portal"
VITE_PRIMARY_COLOR="#00F0FF" # Your Cyber Blue
VITE_SECONDARY_COLOR="#D4AF37" # Your Muted Gold